<% content_for :title, "Sign in · CloudKart POS" %>
<% content_for :hide_nav, true %>
<% content_for :force_splash, true %>

<div class="login-screen">
  <div class="login-card">
    <div class="login-header">
      <div class="login-logo"><i class="fa-solid fa-cash-register"></i></div>
      <h1>CloudKart POS</h1>
      <p>Sign in to manage sales and inventory</p>
    </div>

    <% if flash[:alert] %>
      <div class="login-alert error"><i class="fa-solid fa-circle-exclamation"></i><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="login-alert success"><i class="fa-solid fa-circle-check"></i><%= flash[:notice] %></div>
    <% end %>

    <%= form_with url: login_path, local: true, id: "loginForm" do |form| %>
      <div class="form-group">
        <%= form.label :email, "Email address" %>
        <%= form.email_field :email, required: true, value: params[:email], placeholder: "you@shop.com", autocomplete: "email", class: "form-control" %>
      </div>

      <div class="form-group" style="position:relative;">
        <%= form.label :password %>
        <%= form.password_field :password, required: true, placeholder: "Enter your password", autocomplete: "current-password", id: "passwordField", class: "form-control" %>
        <button type="button" class="pw-toggle" id="passwordToggle" aria-label="Show password">
          <i class="fa-solid fa-eye"></i>
        </button>
      </div>

      <label class="remember-row">
        <%= form.check_box :remember_me %>
        <span>Remember me</span>
      </label>

      <%= form.submit "Sign in", class: "btn btn-primary btn-lg btn-block", id: "loginButton", data: { disable_with: "Signing in…" } %>
    <% end %>

    <div class="login-footer">Powered by <strong>Hamzax Developers</strong> · CloudKart POS</div>
  </div>
</div>

<style>
  .login-screen{
    min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px;
    background:radial-gradient(circle at 20% 20%, #6d5cf0 0%, transparent 45%),
               radial-gradient(circle at 85% 80%, #4f46e5 0%, transparent 45%),
               linear-gradient(135deg,#4338ca 0%,#312e81 100%);
  }
  .login-card{
    width:100%; max-width:400px; background:#fff; border-radius:24px; padding:36px 30px;
    box-shadow:0 30px 70px rgba(0,0,0,.35); animation:scaleIn .4s cubic-bezier(.2,.9,.3,1.1) both; position:relative; overflow:hidden;
  }
  .login-card::before{ content:''; position:absolute; top:0; left:0; right:0; height:5px; background:linear-gradient(90deg,var(--primary),var(--accent)); }
  .login-header{ text-align:center; margin-bottom:24px; }
  .login-logo{
    width:64px; height:64px; margin:0 auto 14px; border-radius:18px; background:linear-gradient(135deg,var(--primary),#7c6cf0);
    color:#fff; display:flex; align-items:center; justify-content:center; font-size:26px; box-shadow:0 10px 24px rgba(79,70,229,.35);
  }
  .login-header h1{ margin:0 0 4px; font-size:22px; font-weight:800; letter-spacing:-.02em; }
  .login-header p{ margin:0; color:var(--text-muted); font-size:13.5px; }
  .login-alert{ display:flex; align-items:center; gap:10px; padding:12px 14px; border-radius:12px; font-size:13.5px; font-weight:600; margin-bottom:16px; animation:fadeInUp .3s ease; }
  .login-alert.error{ background:var(--danger-light); color:var(--danger); }
  .login-alert.success{ background:var(--success-light); color:var(--success); }
  .pw-toggle{ position:absolute; right:12px; top:38px; background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:15px; padding:6px; }
  .pw-toggle:hover{ color:var(--primary); }
  .remember-row{ display:flex; align-items:center; gap:8px; font-size:13.5px; font-weight:600; margin:2px 0 20px; cursor:pointer; }
  .remember-row input{ width:16px; height:16px; accent-color:var(--primary); }
  .login-footer{ text-align:center; margin-top:22px; padding-top:18px; border-top:1px solid var(--border); font-size:12.5px; color:var(--text-muted); }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const pwField = document.getElementById('passwordField');
    const toggle = document.getElementById('passwordToggle');
    if (toggle && pwField) {
      toggle.addEventListener('click', function () {
        const isPw = pwField.getAttribute('type') === 'password';
        pwField.setAttribute('type', isPw ? 'text' : 'password');
        this.innerHTML = isPw ? '<i class="fa-solid fa-eye-slash"></i>' : '<i class="fa-solid fa-eye"></i>';
      });
    }
    const emailField = document.querySelector('input[type="email"]');
    if (emailField) emailField.focus();
  });
</script>
