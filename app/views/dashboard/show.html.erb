<% content_for :title, "Dashboard · CloudKart POS" %>
<% content_for :force_splash, true %>

<div class="app-shell">

  <div class="flex items-center justify-between gap-12" style="margin-bottom:20px; flex-wrap:wrap;">
    <div>
      <h1 style="margin:0; font-size:24px; font-weight:800; letter-spacing:-.02em;">
        Welcome back <span style="color:var(--primary);"><%= Current.shop&.name %></span> 👋
      </h1>
      <p class="text-muted" style="margin:4px 0 0; font-size:14px;">Here's what's happening in your shop today.</p>
    </div>
    <%= link_to new_sale_path, class: "btn btn-primary btn-lg" do %>
      <i class="fa-solid fa-cart-plus"></i> New Sale
    <% end %>
  </div>

  <!-- Quick actions -->
  <div class="stagger" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:14px; margin-bottom:22px;">
    <%= link_to new_sale_path, class: "card card-pad", style: "text-align:center; text-decoration:none; transition:.2s;" do %>
      <div class="section-icon" style="margin:0 auto 10px;"><i class="fa-solid fa-cart-plus"></i></div>
      <div style="font-weight:700; font-size:14.5px; color:var(--text);">New Bill</div>
    <% end %>
    <%= link_to products_path, class: "card card-pad", style: "text-align:center; text-decoration:none;" do %>
      <div class="section-icon" style="margin:0 auto 10px; background:linear-gradient(135deg,#06b6d4,#0891b2);"><i class="fa-solid fa-box"></i></div>
      <div style="font-weight:700; font-size:14.5px; color:var(--text);">Products</div>
    <% end %>
    <%= link_to sales_path, class: "card card-pad", style: "text-align:center; text-decoration:none;" do %>
      <div class="section-icon" style="margin:0 auto 10px; background:linear-gradient(135deg,#16a34a,#15803d);"><i class="fa-solid fa-receipt"></i></div>
      <div style="font-weight:700; font-size:14.5px; color:var(--text);">Sales</div>
    <% end %>
    <a href="#" class="card card-pad" style="text-align:center; text-decoration:none; opacity:.65;">
      <div class="section-icon" style="margin:0 auto 10px; background:linear-gradient(135deg,#f59e0b,#d97706);"><i class="fa-solid fa-chart-column"></i></div>
      <div style="font-weight:700; font-size:14.5px; color:var(--text);">Reports</div>
    </a>
  </div>

  <!-- Stats -->
  <div class="card card-pad" style="margin-bottom:18px;">
    <div class="section-title"><div class="section-icon"><i class="fa-solid fa-chart-pie"></i></div><h2>Quick Stats</h2></div>
    <div class="stagger" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:14px;">
      <div class="card-pad" style="border-radius:16px; background:linear-gradient(135deg,var(--primary),#7c6cf0); color:#fff;">
        <div style="font-size:30px; font-weight:800;"><%= @products.count %></div>
        <div style="opacity:.9; font-size:13px; font-weight:600;">Total Products</div>
      </div>
      <div class="card-pad" style="border-radius:16px; background:linear-gradient(135deg,#f59e0b,#d97706); color:#fff;">
        <div style="font-size:30px; font-weight:800;"><%= @low_stock_count %></div>
        <div style="opacity:.9; font-size:13px; font-weight:600;">Low Stock Items</div>
      </div>
      <div class="card-pad" style="border-radius:16px; background:linear-gradient(135deg,#16a34a,#15803d); color:#fff;">
        <div style="font-size:30px; font-weight:800;"><%= @today_sales.count %></div>
        <div style="opacity:.9; font-size:13px; font-weight:600;">Bills Today</div>
      </div>
    </div>
  </div>

  <!-- Recent sales -->
  <div class="card card-pad" style="margin-bottom:24px;">
    <div class="section-title"><div class="section-icon"><i class="fa-solid fa-clock-rotate-left"></i></div><h2>Recent Sales</h2></div>

    <% if @recent_sales.empty? %>
      <div class="empty-state">
        <div class="empty-icon"><i class="fa-solid fa-receipt"></i></div>
        <h3>No sales yet</h3>
        <p>Sales you complete will show up here.</p>
      </div>
    <% else %>
      <div class="stagger" style="display:flex; flex-direction:column; gap:10px;">
        <% @recent_sales.each do |sale| %>
          <div class="flex items-center gap-12" style="padding:13px 14px; border-radius:14px; background:var(--bg); transition:.2s;">
            <div class="section-icon" style="background:var(--surface); color:var(--primary); border:1px solid var(--border);"><i class="fa-solid fa-receipt"></i></div>
            <div style="flex:1; min-width:0;">
              <div style="font-weight:700; font-size:14.5px;">Sale #INV-<%= sale.id.to_s.rjust(5, "0") %></div>
              <div class="text-muted" style="font-size:12.5px;"><%= time_ago_in_words(sale.created_at) %> ago</div>
            </div>
            <div style="font-weight:750; color:var(--primary); white-space:nowrap;">Rs. <%= number_with_delimiter(sale.total_cents / 100) %></div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
