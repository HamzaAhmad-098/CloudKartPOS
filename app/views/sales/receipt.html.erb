<% content_for :title, "Receipt ##{@sale.invoice_no} · CloudKart POS" %>
<% content_for :hide_nav, true %>

<div class="app-shell receipt-page">
  <div class="flex items-center gap-12" style="margin-bottom:16px;">
    <%= link_to sale_path(@sale), class: "topbar-back" do %><i class="fa-solid fa-arrow-left"></i><% end %>
    <h1 style="margin:0; font-size:19px; font-weight:800;">Receipt</h1>
  </div>

  <div class="receipt">
    <div class="receipt-header">
      <div class="receipt-logo"><i class="fa-solid fa-cash-register"></i></div>
      <h2><%= Current.shop.name %></h2>
      <p><%= Current.shop.address %></p>
      <p>Phone: <%= Current.shop.phone %></p>
    </div>

    <div class="receipt-info">
      <div><span>Invoice #</span><strong><%= @sale.invoice_no %></strong></div>
      <div><span>Date</span><strong><%= @sale.created_at.localtime.strftime("%d/%m/%Y %I:%M %p") %></strong></div>
      <div><span>Cashier</span><strong><%= @sale.user.full_name %></strong></div>
      <% if @sale.customer %>
        <div><span>Customer</span><strong><%= @sale.customer.name %></strong></div>
      <% end %>
    </div>

    <div class="receipt-items">
      <table>
        <thead><tr><th>Item</th><th>Qty</th><th>Price</th><th style="text-align:right;">Total</th></tr></thead>
        <tbody>
          <% @sale.sale_items.each do |item| %>
            <tr>
              <td><%= item.product.name %></td>
              <td><%= item.qty %></td>
              <td>Rs. <%= item.unit_price %></td>
              <td style="text-align:right;">Rs. <%= item.total_price %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="receipt-totals">
      <div class="total-row"><span>Subtotal</span><span>Rs. <%= @sale.subtotal_amount %></span></div>
      <% if @sale.discount_cents > 0 %>
        <div class="total-row"><span>Discount</span><span>-Rs. <%= @sale.discount_amount %></span></div>
      <% end %>
      <% if @sale.tax_cents > 0 %>
        <div class="total-row"><span>Tax</span><span>Rs. <%= @sale.tax_amount %></span></div>
      <% end %>
      <div class="total-row grand-total"><span>Total</span><span>Rs. <%= @sale.total_amount %></span></div>
    </div>

    <div class="receipt-footer">
      <p><strong>Payment:</strong> <%= @sale.payment_method.to_s.humanize %></p>
      <p class="thank-you">✦ Thank you for shopping with us ✦</p>
    </div>
  </div>

  <div class="flex gap-10" style="margin:18px 0;">
    <button type="button" class="btn btn-primary" style="flex:1;" onclick="window.print()"><i class="fa-solid fa-print"></i> Print</button>
    <%= link_to new_sale_path, class: "btn btn-success", style: "flex:1;" do %><i class="fa-solid fa-cart-plus"></i> New Sale<% end %>
    <%= link_to sales_path, class: "btn btn-outline", style: "flex:1;" do %><i class="fa-solid fa-list"></i> All Sales<% end %>
  </div>

  <!-- WhatsApp share -->
  <div class="card card-pad whatsapp-card">
    <div class="section-title"><div class="section-icon" style="background:linear-gradient(135deg,#25D366,#128C7E);"><i class="fa-brands fa-whatsapp"></i></div><h3>Send Receipt via WhatsApp</h3></div>
    <p class="text-muted" style="font-size:13.5px; margin:0 0 14px;">Enter the customer's WhatsApp number to share this receipt instantly.</p>
    <div class="flex gap-10">
      <input type="tel" id="whatsappNumber" class="form-control" placeholder="e.g. 03001234567" pattern="[0-9]{11}" maxlength="11">
      <button class="btn" style="background:#25D366; color:#fff; flex-shrink:0;" onclick="sendWhatsAppReceipt()"><i class="fa-brands fa-whatsapp"></i> Send</button>
    </div>
    <div class="form-hint">11-digit Pakistani number without country code (e.g. 03001234567)</div>
    <div id="whatsappStatus" class="whatsapp-status" style="display:none;"></div>
  </div>
</div>

<script>
const receiptData = <%= {
  shop_name: Current.shop.name,
  shop_address: Current.shop.address,
  shop_phone: Current.shop.phone,
  invoice_no: @sale.invoice_no,
  date: @sale.created_at.localtime.strftime("%d/%m/%Y %I:%M %p"),
  cashier: @sale.user.full_name,
  customer: (@sale.customer&.name || ""),
  items: @sale.sale_items.map { |i|
    { name: i.product.name, qty: i.qty, unit_price: i.unit_price, total_price: i.total_price }
  },
  subtotal: @sale.subtotal_amount,
  discount: @sale.discount_amount,
  has_discount: @sale.discount_cents > 0,
  tax: @sale.tax_amount,
  has_tax: @sale.tax_cents > 0,
  total: @sale.total_amount,
  payment_method: @sale.payment_method.to_s.humanize
}.to_json.html_safe %>;
</script>

<style>
  .receipt{ max-width:400px; margin:0 auto; background:#fff; border:1px solid var(--border); border-radius:var(--radius); padding:24px 20px; font-family:'Courier New',monospace; box-shadow:var(--shadow); }
  .receipt-header{ text-align:center; border-bottom:2px dashed var(--border); padding-bottom:16px; margin-bottom:16px; }
  .receipt-logo{ width:44px; height:44px; margin:0 auto 10px; border-radius:50%; background:linear-gradient(135deg,var(--primary),#7c6cf0); color:#fff; display:flex; align-items:center; justify-content:center; font-size:18px; }
  .receipt-header h2{ margin:0 0 4px; font-size:1.3em; }
  .receipt-header p{ margin:0; font-size:.85em; color:var(--text-muted); }
  .receipt-info{ margin-bottom:14px; font-size:.85em; }
  .receipt-info div{ display:flex; justify-content:space-between; padding:3px 0; }
  .receipt-info span{ color:var(--text-muted); }
  .receipt-items table{ width:100%; border-collapse:collapse; margin-bottom:14px; font-size:.85em; }
  .receipt-items th{ text-align:left; border-bottom:1px solid var(--border); padding:5px 0; }
  .receipt-items td{ padding:4px 0; border-bottom:1px dashed var(--border); }
  .receipt-totals{ border-top:2px dashed var(--border); padding-top:10px; font-size:.9em; }
  .total-row{ display:flex; justify-content:space-between; margin-bottom:5px; }
  .total-row.grand-total{ border-top:1px solid var(--text); padding-top:6px; font-size:1.15em; font-weight:800; }
  .receipt-footer{ text-align:center; border-top:2px dashed var(--border); padding-top:14px; margin-top:14px; font-size:.85em; }
  .thank-you{ font-style:italic; margin-top:8px; color:var(--primary); }
  .whatsapp-status{ margin-top:12px; padding:10px 12px; border-radius:10px; font-weight:600; font-size:13.5px; }
  .whatsapp-status.success{ background:var(--success-light); color:var(--success); }
  .whatsapp-status.error{ background:var(--danger-light); color:var(--danger); }
  @media print{
    .flex, .whatsapp-card, .topbar-back{ display:none !important; }
    .receipt{ border:none; box-shadow:none; }
    body{ background:#fff; padding-bottom:0; }
  }
</style>

<script>
function sendWhatsAppReceipt() {
  const phoneInput = document.getElementById('whatsappNumber');
  const statusDiv = document.getElementById('whatsappStatus');
  const phoneNumber = phoneInput.value.trim();

  const phoneRegex = /^[0-9]{11}$/;
  if (!phoneRegex.test(phoneNumber)) {
    statusDiv.textContent = 'Please enter a valid 11-digit phone number';
    statusDiv.className = 'whatsapp-status error';
    statusDiv.style.display = 'block';
    window.POS && window.POS.toast('Enter a valid 11-digit number', 'error');
    return;
  }

  const formattedNumber = '92' + phoneNumber.substring(1);
  const receiptMessage = createReceiptMessage();
  const encodedMessage = encodeURIComponent(receiptMessage);
  const whatsappUrl = `https://wa.me/${formattedNumber}?text=${encodedMessage}`;
  window.open(whatsappUrl, '_blank');

  statusDiv.textContent = 'WhatsApp opened with receipt. Click send.';
  statusDiv.className = 'whatsapp-status success';
  statusDiv.style.display = 'block';
  window.POS && window.POS.toast('WhatsApp opened', 'success');

  phoneInput.value = '';
  setTimeout(() => { statusDiv.style.display = 'none'; }, 5000);
}

function createReceiptMessage() {
  return `
*${receiptData.shop_name}*
${receiptData.shop_address}
Phone: ${receiptData.shop_phone}

*INVOICE RECEIPT*

Invoice #: ${receiptData.invoice_no}
Date: ${receiptData.date}
Cashier: ${receiptData.cashier}
${receiptData.customer ? `Customer: ${receiptData.customer}` : ''}

*ITEMS*
${receiptData.items.map(item =>
  `${item.name} - ${item.qty} x Rs. ${item.unit_price} = Rs. ${item.total_price}`
).join('\n')}

*TOTALS*
Subtotal: Rs. ${receiptData.subtotal}
${receiptData.has_discount ? `Discount: -Rs. ${receiptData.discount}\n` : ''}
${receiptData.has_tax ? `Tax: Rs. ${receiptData.tax}\n` : ''}
*GRAND TOTAL: Rs. ${receiptData.total}*

Payment Method: ${receiptData.payment_method}

Thank you for your shopping! 🛍️
`.trim();
}

document.getElementById('whatsappNumber').addEventListener('keypress', function (e) {
  if (e.key === 'Enter') sendWhatsAppReceipt();
});
</script>
