<% content_for :title, "Invoice ##{@sale.invoice_no} · CloudKart POS" %>

<div class="app-shell">
  <div class="flex items-center justify-between" style="margin-bottom:18px; flex-wrap:wrap; gap:12px;">
    <div class="flex items-center gap-12">
      <%= link_to sales_path, class: "topbar-back" do %><i class="fa-solid fa-arrow-left"></i><% end %>
      <div>
        <h1 style="margin:0; font-size:20px; font-weight:800;">Invoice #<%= @sale.invoice_no %></h1>
        <p class="text-muted" style="margin:2px 0 0; font-size:13.5px;"><%= @sale.created_at.strftime("%d %b %Y, %I:%M %p") %></p>
      </div>
    </div>
    <%= link_to receipt_sale_path(@sale), class: "btn btn-primary" do %><i class="fa-solid fa-receipt"></i> View Receipt<% end %>
  </div>

  <div class="card card-pad" style="margin-bottom:18px;">
    <div class="form-row" style="margin-bottom:4px;">
      <div>
        <div class="detail-line"><span>Cashier</span><strong><%= @sale.user.full_name %></strong></div>
        <div class="detail-line"><span>Customer</span><strong><%= @sale.customer&.name || "Walk-in" %></strong></div>
      </div>
      <div>
        <div class="detail-line"><span>Payment</span><span class="badge badge-primary"><%= @sale.payment_method.to_s.humanize %></span></div>
        <div class="detail-line"><span>Total</span><strong style="color:var(--success); font-size:16px;">Rs. <%= @sale.total_amount %></strong></div>
      </div>
    </div>
  </div>

  <div class="card card-pad">
    <div class="section-title"><div class="section-icon"><i class="fa-solid fa-basket-shopping"></i></div><h2>Items Sold</h2></div>

    <!-- Desktop table -->
    <table class="items-table">
      <thead>
        <tr><th>Product</th><th>Qty</th><th>Unit Price</th><th style="text-align:right;">Total</th></tr>
      </thead>
      <tbody>
        <% @sale.sale_items.each do |item| %>
          <tr>
            <td><%= item.product.name %></td>
            <td><%= item.qty %></td>
            <td>Rs. <%= item.unit_price %></td>
            <td style="text-align:right; font-weight:700;">Rs. <%= item.total_price %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<style>
  .detail-line{ display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px dashed var(--border); font-size:14px; }
  .detail-line span:first-child{ color:var(--text-muted); }
  .items-table{ width:100%; border-collapse:collapse; }
  .items-table th{ text-align:left; padding:10px 8px; font-size:12.5px; text-transform:uppercase; letter-spacing:.03em; color:var(--text-muted); border-bottom:2px solid var(--border); }
  .items-table td{ padding:12px 8px; border-bottom:1px solid var(--border); font-size:14.5px; }
  .items-table tr:last-child td{ border-bottom:none; }
</style>
