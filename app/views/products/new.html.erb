<% content_for :title, "Add Product · CloudKart POS" %>
<% content_for :head do %>
  <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
<% end %>

<div class="app-shell" style="max-width:640px;">
  <div class="flex items-center gap-12" style="margin-bottom:18px;">
    <%= link_to products_path, class: "topbar-back" do %><i class="fa-solid fa-arrow-left"></i><% end %>
    <div>
      <h1 style="margin:0; font-size:20px; font-weight:800;">Add New Product</h1>
      <p class="text-muted" style="margin:2px 0 0; font-size:13.5px;">Scan a barcode or fill in the details below.</p>
    </div>
  </div>

  <div class="pos-quick-actions">
    <button type="button" class="pos-action-card" onclick="productForm.openScanner()">
      <i class="fa-solid fa-barcode"></i><span>Scan Barcode</span>
    </button>
    <button type="button" class="pos-action-card" onclick="clearForm()">
      <i class="fa-solid fa-eraser"></i><span>Clear Form</span>
    </button>
  </div>

  <%= form_with model: @product, local: true, html: { class: "product-form", id: "product-form" } do |form| %>
    <!-- Barcode -->
    <div class="barcode-banner">
      <%= form.label :barcode, "PRODUCT BARCODE", style: "color:#fff; font-size:12px; letter-spacing:.04em;" %>
      <div class="flex gap-10" style="margin-top:8px;">
        <%= form.text_field :barcode, required: true, class: "form-control barcode-input", placeholder: "Scan or enter barcode",
              id: "product_barcode", pattern: "[0-9]+", inputmode: "numeric" %>
        <button type="button" class="btn btn-icon" id="scanBarcodeBtn" style="background:rgba(255,255,255,.2); color:#fff;" onclick="productForm.openScanner()">
          <i class="fa-solid fa-barcode"></i>
        </button>
      </div>
      <div id="barcodeValidation" class="barcode-validation">
        <span id="barcodeStatusIcon"><i class="fa-solid fa-magnifying-glass"></i></span>
        <span id="barcodeStatusText">Scan or enter barcode</span>
      </div>
      <label class="no-barcode-toggle">
        <input type="checkbox" id="no_barcode_toggle">
        <span>This product has no barcode</span>
      </label>
    </div>

    <!-- Details -->
    <div class="card card-pad" style="margin-bottom:16px;">
      <div class="section-title"><div class="section-icon"><i class="fa-solid fa-box"></i></div><h3>Product Information</h3></div>
      <div class="form-group">
        <%= form.label :name, "Product Name *" %>
        <%= form.text_field :name, required: true, class: "form-control", placeholder: "Enter product name", id: "product_name" %>
      </div>
      <div class="form-row">
        <div class="form-group">
          <%= form.label :brand, "Brand" %>
          <%= form.text_field :brand, class: "form-control", placeholder: "Brand name", id: "product_brand" %>
        </div>
        <div class="form-group">
          <%= form.label :category_id, "Category" %>
          <%= form.collection_select :category_id, @categories, :id, :name, { include_blank: "Select" }, class: "form-control" %>
        </div>
      </div>
    </div>

    <!-- Pricing -->
    <div class="card card-pad" style="margin-bottom:16px;">
      <div class="section-title"><div class="section-icon" style="background:linear-gradient(135deg,#16a34a,#15803d);"><i class="fa-solid fa-tag"></i></div><h3>Pricing & Stock</h3></div>
      <div class="form-row">
        <div class="form-group">
          <%= form.label :purchase_price_cents, "Cost Price (Rs) *" %>
          <%= form.number_field :purchase_price_cents, step: 1, min: 0, required: true, class: "form-control",
                placeholder: "0", inputmode: "numeric", id: "purchase_price_input" %>
        </div>
        <div class="form-group">
          <%= form.label :selling_price_cents, "Selling Price (Rs) *" %>
          <%= form.number_field :selling_price_cents, step: 1, min: 0, required: true, class: "form-control",
                placeholder: "0", inputmode: "numeric", id: "selling_price_input" %>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <%= form.label :current_stock, "Stock *" %>
          <%= form.number_field :current_stock, step: 1, min: 0, required: true, class: "form-control",
                value: @product.current_stock || 0, inputmode: "numeric" %>
        </div>
        <div class="form-group">
          <%= form.label :unit, "Unit" %>
          <%= form.select :unit, options_for_select(['pcs', 'kg', 'L', 'pack', 'box'], @product.unit), { include_blank: "Unit" }, class: "form-control" %>
        </div>
      </div>
    </div>

    <div class="sticky-actions">
      <%= form.submit "Save Product", class: "btn btn-success btn-block btn-lg", id: "submit_btn", data: { turbo: false } %>
    </div>
  <% end %>
</div>

<!-- Barcode scanner modal -->
<div id="scannerSection" class="scanner-modal">
  <div class="scanner-modal-header">
    <h3><i class="fa-solid fa-barcode"></i> Scan Barcode</h3>
    <p id="scannerStatus">Starting camera...</p>
  </div>
  <div id="qr-reader"></div>
  <video id="nativeScannerVideo" playsinline muted style="display:none; width:100%; height:100%; object-fit:cover;"></video>
  <div class="scanner-frame-overlay">
    <div class="scanner-frame">
      <div class="scanner-corners">
        <div class="corner top-left"></div><div class="corner top-right"></div>
        <div class="corner bottom-left"></div><div class="corner bottom-right"></div>
      </div>
    </div>
    <div class="scanner-hint">Align barcode within frame</div>
  </div>
  <div class="scanner-controls">
    <button class="btn btn-danger" style="flex:1;" onclick="productForm.closeScanner()"><i class="fa-solid fa-xmark"></i> Cancel</button>
    <button class="btn btn-warning" style="flex:1;" onclick="productForm.switchCamera()"><i class="fa-solid fa-camera-rotate"></i> Flip</button>
  </div>
</div>

<style>
  .pos-quick-actions{ display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:18px; }
  .pos-action-card{
    background:var(--surface); border:1.6px solid var(--border); border-radius:16px; padding:18px 10px;
    text-align:center; cursor:pointer; transition:.2s; display:flex; flex-direction:column; align-items:center; gap:8px;
    font-family:inherit; font-weight:700; font-size:13.5px; color:var(--text);
  }
  .pos-action-card i{ font-size:24px; color:var(--primary); }
  .pos-action-card:active{ transform:scale(.97); border-color:var(--primary); }

  .barcode-banner{ background:linear-gradient(135deg,#f093fb 0%,#f5576c 100%); border-radius:18px; padding:20px; margin-bottom:16px; color:#fff; }
  .barcode-input{ background:rgba(255,255,255,.95); border:none; color:var(--text); flex:1; }
  .barcode-validation{ display:flex; align-items:center; gap:8px; font-size:13.5px; margin-top:10px; font-weight:600; }
  .no-barcode-toggle{ display:flex; align-items:center; gap:8px; margin-top:12px; font-size:13.5px; font-weight:600; color:#fff; cursor:pointer; user-select:none; }
  .no-barcode-toggle input[type="checkbox"]{ width:18px; height:18px; accent-color:#fff; cursor:pointer; }

  .sticky-actions{ position:sticky; bottom:14px; background:var(--surface); padding:14px; border-radius:16px; border:1px solid var(--border); box-shadow:var(--shadow); margin-top:4px; }

  .scanner-modal{ display:none; position:fixed; inset:0; background:#000; z-index:10000; flex-direction:column; }
  .scanner-modal-header{ background:rgba(0,0,0,.9); color:#fff; padding:18px; text-align:center; z-index:10001; }
  #qr-reader{ flex:1; width:100%; position:relative; display:flex; align-items:center; justify-content:center; }
  #qr-reader video{ width:100% !important; height:100% !important; object-fit:cover !important; }
  #qr-reader__dashboard_section{ display:none !important; }
  .scanner-frame-overlay{ position:absolute; inset:0; pointer-events:none; z-index:10001; display:flex; flex-direction:column; justify-content:center; align-items:center; }
  .scanner-frame{ width:80%; max-width:300px; height:200px; border:3px solid var(--success); border-radius:20px; position:relative; box-shadow:0 0 0 2000px rgba(0,0,0,.5); animation:scannerPulse 2s infinite; }
  @keyframes scannerPulse{ 0%,100%{ border-color:var(--success);} 50%{ border-color:#5eead4;} }
  .corner{ position:absolute; width:30px; height:30px; border:4px solid var(--success); }
  .corner.top-left{ top:-3px; left:-3px; border-right:none; border-bottom:none; }
  .corner.top-right{ top:-3px; right:-3px; border-left:none; border-bottom:none; }
  .corner.bottom-left{ bottom:-3px; left:-3px; border-right:none; border-top:none; }
  .corner.bottom-right{ bottom:-3px; right:-3px; border-left:none; border-top:none; }
  .scanner-hint{ color:#fff; margin-top:30px; font-size:16px; text-align:center; background:rgba(0,0,0,.7); padding:15px 25px; border-radius:25px; font-weight:600; }
  .scanner-controls{ display:flex; gap:15px; padding:20px; background:rgba(0,0,0,.9); z-index:10001; }
</style>

<script>
// Special (non-numeric) marker for products with no real barcode.
// Uses a dash-separated, non-numeric prefix so it can never collide with a
// real scanned barcode (which is always digits-only), plus a UUID/random
// suffix so it never collides with another "no barcode" product either.
const NO_BARCODE_PREFIX = 'NO-BARCODE-';
function generateNoBarcodeValue() {
  const unique = (window.crypto && typeof crypto.randomUUID === 'function')
    ? crypto.randomUUID()
    : (Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 10));
  return NO_BARCODE_PREFIX + unique;
}
function isNoBarcodeValue(value) {
  return typeof value === 'string' && value.startsWith(NO_BARCODE_PREFIX);
}

function isValidBarcodeChecksum(code) {
  const digits = code.split('').map(Number);
  const len = digits.length;
  if (len === 13) { let sum = 0; for (let i = 0; i < 12; i++) sum += digits[i] * (i % 2 === 0 ? 1 : 3); return ((10 - (sum % 10)) % 10) === digits[12]; }
  if (len === 12) { let sum = 0; for (let i = 0; i < 11; i++) sum += digits[i] * (i % 2 === 0 ? 3 : 1); return ((10 - (sum % 10)) % 10) === digits[11]; }
  if (len === 8)  { let sum = 0; for (let i = 0; i < 7;  i++) sum += digits[i] * (i % 2 === 0 ? 3 : 1); return ((10 - (sum % 10)) % 10) === digits[7]; }
  return true;
}

class ProductForm {
  constructor() {
    this.scanner = null;
    this.isBackCamera = true;
    this.isScanning = false;
    this.lastScannedCode = null;
    this.scanCooldown = false;
    this.initialized = false;
    this.init();
  }
  init() {
    if (this.initialized) return;
    this.setupBarcodeValidation();
    this.setupFormEnhancements();
    this.setupEventListeners();
    this.setupNoBarcodeToggle();
    this.initialized = true;
  }
  setupNoBarcodeToggle() {
    const toggle = document.getElementById('no_barcode_toggle');
    if (!toggle) return;
    toggle.addEventListener('change', (e) => this.toggleNoBarcode(e.target.checked));
  }
  toggleNoBarcode(checked) {
    const barcodeField = document.getElementById('product_barcode');
    const scanBtn = document.getElementById('scanBarcodeBtn');
    const statusIcon = document.getElementById('barcodeStatusIcon');
    const statusText = document.getElementById('barcodeStatusText');
    if (!barcodeField) return;

    if (checked) {
      // Remember whatever the user had typed so we can restore it if they untick the toggle.
      this._manualBarcodeValue = isNoBarcodeValue(barcodeField.value) ? '' : barcodeField.value;
      barcodeField.value = generateNoBarcodeValue();
      barcodeField.readOnly = true;
      barcodeField.removeAttribute('pattern');
      barcodeField.removeAttribute('inputmode');
      barcodeField.classList.add('is-no-barcode');
      if (scanBtn) { scanBtn.disabled = true; scanBtn.style.opacity = '0.5'; scanBtn.style.pointerEvents = 'none'; }
      if (statusIcon) statusIcon.innerHTML = '<i class="fa-solid fa-ban"></i>';
      if (statusText) statusText.textContent = 'No barcode — auto-generated ID assigned';
    } else {
      barcodeField.readOnly = false;
      barcodeField.setAttribute('pattern', '[0-9]+');
      barcodeField.setAttribute('inputmode', 'numeric');
      barcodeField.classList.remove('is-no-barcode');
      barcodeField.value = this._manualBarcodeValue || '';
      if (scanBtn) { scanBtn.disabled = false; scanBtn.style.opacity = ''; scanBtn.style.pointerEvents = ''; }
      this.validateBarcode(barcodeField.value);
    }
  }
  destroy() { this.closeScanner(); this.initialized = false; }
  setupEventListeners() {
    const form = document.getElementById('product-form');
    if (form) form.addEventListener('submit', (e) => this.handleFormSubmit(e));
  }
  setupBarcodeValidation() {
    const barcodeField = document.getElementById('product_barcode');
    if (barcodeField) {
      barcodeField.addEventListener('input', (e) => this.validateBarcode(e.target.value));
      if (barcodeField.value) this.validateBarcode(barcodeField.value);
    }
  }
  setupFormEnhancements() {
    const barcodeField = document.getElementById('product_barcode');
    const nameField = document.getElementById('product_name');
    if (barcodeField && nameField) {
      barcodeField.addEventListener('change', () => {
        if (barcodeField.value.length >= 8 && !nameField.value) setTimeout(() => nameField.focus(), 100);
      });
    }
  }
  handleFormSubmit(e) {
    const submitBtn = document.getElementById('submit_btn');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.value = 'Saving...'; }
    const sellingPriceInput = document.getElementById('selling_price_input');
    if (sellingPriceInput && sellingPriceInput.value) {
      const price = parseInt(sellingPriceInput.value);
      if (price <= 0) {
        POS.toast('Please enter a valid selling price', 'error');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.value = 'Save Product'; }
        e.preventDefault(); return;
      }
    }
    const purchasePriceInput = document.getElementById('purchase_price_input');
    if (purchasePriceInput && purchasePriceInput.value) {
      const price = parseInt(purchasePriceInput.value);
      if (price < 0) {
        POS.toast('Purchase price cannot be negative', 'error');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.value = 'Save Product'; }
        e.preventDefault(); return;
      }
    }
    setTimeout(() => { if (submitBtn) { submitBtn.disabled = false; submitBtn.value = 'Save Product'; } }, 3000);
  }
  validateBarcode(barcode) {
    const statusIcon = document.getElementById('barcodeStatusIcon');
    const statusText = document.getElementById('barcodeStatusText');
    if (isNoBarcodeValue(barcode)) { statusIcon.innerHTML = '<i class="fa-solid fa-ban"></i>'; statusText.textContent = 'No barcode — auto-generated ID assigned'; return true; }
    if (!barcode) { statusIcon.innerHTML = '<i class="fa-solid fa-magnifying-glass"></i>'; statusText.textContent = 'Scan or enter barcode'; return false; }
    const isValid = /^\d{8,20}$/.test(barcode);
    if (isValid) { statusIcon.innerHTML = '<i class="fa-solid fa-circle-check"></i>'; statusText.textContent = 'Valid barcode'; return true; }
    statusIcon.innerHTML = '<i class="fa-solid fa-circle-xmark"></i>'; statusText.textContent = 'Enter 8-20 digits'; return false;
  }
  async openScanner() {
    if (this.isScanning) return;
    const scannerSection = document.getElementById('scannerSection');
    const scannerStatus = document.getElementById('scannerStatus');
    scannerSection.style.display = 'flex';
    scannerStatus.textContent = 'Starting camera...';
    this.isScanning = true;
    this.pendingCode = null; this.pendingCount = 0;
    const formats = ['ean_13', 'ean_8', 'upc_a', 'upc_e', 'code_128'];
    if ('BarcodeDetector' in window) {
      try { await this.startNativeScanner(formats); return; }
      catch (error) { console.warn('Native scanner unavailable, falling back:', error); }
    }
    await this.startHtml5QrcodeScanner();
  }
  async startNativeScanner(formats) {
    const video = document.getElementById('nativeScannerVideo');
    document.getElementById('qr-reader').style.display = 'none';
    video.style.display = 'block';
    this.usingNativeDetector = true;
    this.detector = new BarcodeDetector({ formats });
    this.nativeStream = await navigator.mediaDevices.getUserMedia({
      video: { facingMode: this.isBackCamera ? 'environment' : 'user', advanced: [{ focusMode: 'continuous' }] }
    });
    video.srcObject = this.nativeStream;
    await video.play();
    const scannerStatus = document.getElementById('scannerStatus');
    scannerStatus.textContent = '✓ Camera ready - Point at barcode';
    scannerStatus.style.color = '#4ade80';
    this.nativeDetectLoop(video);
  }
  async nativeDetectLoop(video) {
    if (!this.isScanning || !this.usingNativeDetector) return;
    try { const barcodes = await this.detector.detect(video); if (barcodes.length > 0) this.onScanSuccess(barcodes[0].rawValue); }
    catch (error) {}
    if (this.isScanning && this.usingNativeDetector) requestAnimationFrame(() => this.nativeDetectLoop(video));
  }
  async startHtml5QrcodeScanner() {
    this.usingNativeDetector = false;
    document.getElementById('qr-reader').style.display = 'block';
    document.getElementById('nativeScannerVideo').style.display = 'none';
    const scannerStatus = document.getElementById('scannerStatus');
    try {
      this.scanner = new Html5Qrcode("qr-reader");
      const devices = await Html5Qrcode.getCameras();
      if (!devices || devices.length === 0) throw new Error('No cameras found');
      const cameraId = this.isBackCamera && devices.length > 1 ? devices[devices.length - 1].id : devices[0].id;
      const config = {
        fps: 15, qrbox: { width: 250, height: 150 }, aspectRatio: 1.7, disableFlip: false,
        formatsToSupport: [
          Html5QrcodeSupportedFormats.EAN_13, Html5QrcodeSupportedFormats.EAN_8,
          Html5QrcodeSupportedFormats.UPC_A, Html5QrcodeSupportedFormats.UPC_E, Html5QrcodeSupportedFormats.CODE_128
        ],
        videoConstraints: { facingMode: this.isBackCamera ? "environment" : "user", advanced: [{ focusMode: "continuous" }] }
      };
      await this.scanner.start(cameraId, config, (decodedText, decodedResult) => this.onScanSuccess(decodedText, decodedResult), () => {});
      scannerStatus.textContent = '✓ Camera ready - Point at barcode';
      scannerStatus.style.color = '#4ade80';
    } catch (error) { this.handleScannerError(error); }
  }
  handleScannerError(error) {
    const scannerStatus = document.getElementById('scannerStatus');
    let message = 'Camera error. ';
    if (error.message.includes('NotAllowedError') || error.message.includes('Permission denied')) message = 'Camera permission denied. Please allow camera access and try again.';
    else if (error.message.includes('NotFoundError') || error.message.includes('No cameras found')) message = 'No camera found on this device.';
    else if (error.message.includes('NotReadableError')) message = 'Camera is being used by another app.';
    else if (error.message.includes('InsecureContextError') || error.message.includes('secure')) message = 'Camera requires HTTPS connection.';
    else message = error.message;
    scannerStatus.textContent = message;
    scannerStatus.style.color = '#f87171';
    POS.toast(message, 'error');
    setTimeout(() => { this.closeScanner(); }, 3000);
  }
  onScanSuccess(decodedText, decodedResult) {
    if (this.scanCooldown) return;
    const cleanBarcode = decodedText.replace(/\D/g, '');
    const allowedLengths = [8, 12, 13, 14];
    if (!allowedLengths.includes(cleanBarcode.length)) { POS.toast('Scanned code is not a valid product barcode', 'error'); return; }
    if (!isValidBarcodeChecksum(cleanBarcode)) { this.pendingCode = null; this.pendingCount = 0; return; }
    if (this.pendingCode === cleanBarcode) this.pendingCount = (this.pendingCount || 0) + 1;
    else { this.pendingCode = cleanBarcode; this.pendingCount = 1; }
    if (this.pendingCount < 2) return;
    if (cleanBarcode === this.lastScannedCode) return;
    this.lastScannedCode = cleanBarcode;
    this.scanCooldown = true;
    this.pendingCode = null; this.pendingCount = 0;
    const scannerStatus = document.getElementById('scannerStatus');
    scannerStatus.textContent = '✅ Barcode Scanned!';
    scannerStatus.style.color = '#4ade80';
    document.getElementById('product_barcode').value = cleanBarcode;
    this.validateBarcode(cleanBarcode);
    POS.beep('success');
    POS.toast('Barcode scanned: ' + cleanBarcode, 'success');
    setTimeout(() => {
      this.closeScanner();
      const nameField = document.getElementById('product_name');
      if (nameField) nameField.focus();
    }, 1000);
  }
  async switchCamera() {
    if (!this.isScanning) return;
    this.isBackCamera = !this.isBackCamera;
    await this.closeScanner();
    setTimeout(() => { this.openScanner(); }, 300);
  }
  async closeScanner() {
    if (this.usingNativeDetector) {
      if (this.nativeStream) { this.nativeStream.getTracks().forEach(track => track.stop()); this.nativeStream = null; }
      const video = document.getElementById('nativeScannerVideo');
      if (video) video.srcObject = null;
    } else if (this.scanner) {
      try { await this.scanner.stop(); this.scanner.clear(); } catch (error) {}
      this.scanner = null;
    }
    document.getElementById('scannerSection').style.display = 'none';
    this.isScanning = false;
    this.usingNativeDetector = false;
    this.scanCooldown = false;
    this.lastScannedCode = null;
    this.pendingCode = null; this.pendingCount = 0;
  }
}

function clearForm() {
  POS.confirm({
    title: 'Clear form?', body: 'All entered fields will be cleared.', confirmText: 'Clear', confirmClass: 'btn-danger',
    onConfirm: () => {
      document.getElementById('product-form').reset();
      const toggle = document.getElementById('no_barcode_toggle');
      if (toggle && toggle.checked) {
        toggle.checked = false;
        if (window.productForm) window.productForm.toggleNoBarcode(false);
      }
      if (window.productForm) window.productForm.validateBarcode('');
      POS.toast('Form cleared', 'info');
    }
  });
}

function initializeProductForm() {
  if (window.productForm && typeof window.productForm.destroy === 'function') window.productForm.destroy();
  window.productForm = new ProductForm();
}
document.addEventListener('DOMContentLoaded', initializeProductForm);
document.addEventListener('turbo:load', initializeProductForm);
document.addEventListener('turbolinks:load', initializeProductForm);

document.addEventListener('DOMContentLoaded', function () {
  const barcodeField = document.getElementById('product_barcode');
  if (barcodeField && !barcodeField.value) setTimeout(() => barcodeField.focus(), 500);
});
document.addEventListener('visibilitychange', function () {
  if (document.hidden && window.productForm && window.productForm.isScanning) window.productForm.closeScanner();
});
window.addEventListener('beforeunload', function () {
  if (window.productForm && window.productForm.isScanning) window.productForm.closeScanner();
});
</script>
