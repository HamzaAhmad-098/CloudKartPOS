<% content_for :title, "Products · CloudKart POS" %>

<div class="app-shell">
  <div class="flex items-center justify-between" style="margin-bottom:18px; flex-wrap:wrap; gap:12px;">
    <div>
      <h1 style="margin:0; font-size:22px; font-weight:800; letter-spacing:-.02em;">Product Inventory</h1>
      <p class="text-muted" style="margin:4px 0 0; font-size:14px;">Manage what's on your shelves.</p>
    </div>
    <div class="flex gap-10">
      <%= link_to bulk_import_products_path, class: "btn btn-outline btn-sm" do %><i class="fa-solid fa-file-import"></i> Import<% end %>
      <%= link_to new_product_path, class: "btn btn-primary btn-sm" do %><i class="fa-solid fa-plus"></i> Add Product<% end %>
    </div>
  </div>

  <!-- Stats -->
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:20px;">
    <div class="card card-pad" style="text-align:center;">
      <div style="font-size:26px; font-weight:800; color:var(--primary);"><%= @products.count %></div>
      <div class="text-muted" style="font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.03em;">Total Products</div>
    </div>
    <div class="card card-pad" style="text-align:center;">
      <div style="font-size:26px; font-weight:800; color:var(--danger);"><%= @products.count { |p| p.current_stock <= p.reorder_level } %></div>
      <div class="text-muted" style="font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.03em;">Low Stock</div>
    </div>
  </div>

  <!-- Search & filters -->
  <div class="card card-pad" style="margin-bottom:20px;">
    <%= form_with url: products_path, method: :get, local: true do |form| %>
      <div class="flex gap-10" style="margin-bottom:14px;">
        <%= form.text_field :search, placeholder: "Search products...", value: params[:search], class: "form-control" %>
        <%= form.submit "Search", class: "btn btn-primary", style: "flex-shrink:0;" %>
      </div>
    <% end %>
    <div class="filter-scroll">
      <%= link_to "All Products", products_path, class: "filter-chip #{'active' unless params[:low_stock]}" %>
      <%= link_to "Low Stock", products_path(low_stock: true), class: "filter-chip #{'active' if params[:low_stock]}" %>
    </div>
  </div>

  <!-- Products -->
  <div class="card card-pad">
    <div class="section-title"><div class="section-icon"><i class="fa-solid fa-box"></i></div><h2>Product List</h2></div>

    <% if @products.empty? %>
      <div class="empty-state">
        <div class="empty-icon"><i class="fa-solid fa-box-open"></i></div>
        <h3>No products found</h3>
        <% if params[:search] || params[:low_stock] %>
          <p>Try adjusting your search or filters.</p>
        <% else %>
          <p>Add your first product to start selling.</p>
        <% end %>
        <%= link_to new_product_path, class: "btn btn-primary" do %><i class="fa-solid fa-plus"></i> Add Your First Product<% end %>
      </div>
    <% else %>
      <!-- Desktop table -->
      <table class="products-table">
        <thead>
          <tr><th>Product</th><th>Barcode</th><th>Category</th><th>Price</th><th>Stock</th><th></th></tr>
        </thead>
        <tbody>
          <% @products.each do |product| %>
            <tr class="<%= 'low-row' if product.current_stock <= product.reorder_level %>">
              <td>
                <div class="flex items-center gap-12">
                  <% if product.photo.attached? %>
                    <%= image_tag product.photo, class: "prod-thumb" %>
                  <% else %>
                    <div class="prod-thumb placeholder"><i class="fa-solid fa-box"></i></div>
                  <% end %>
                  <div>
                    <div style="font-weight:700;"><%= product.name %></div>
                    <% if product.brand.present? %><div class="text-muted" style="font-size:12px;"><%= product.brand %></div><% end %>
                  </div>
                </div>
              </td>
              <td class="text-muted"><%= product.barcode %></td>
              <td><%= product.category&.name || "Uncategorized" %></td>
              <td style="font-weight:700;">Rs. <%= product.selling_price_cents %></td>
              <td>
                <span class="badge <%= product.current_stock <= product.reorder_level ? 'badge-danger' : 'badge-success' %>">
                  <%= product.current_stock %> <%= product.unit %>
                </span>
              </td>
              <td>
                <div class="flex gap-10">
                  <%= link_to edit_product_path(product), class: "btn btn-icon btn-secondary", title: "Edit" do %><i class="fa-solid fa-pen"></i><% end %>
                  <button type="button" class="btn btn-icon btn-danger" title="Delete"
                          onclick="deleteProduct('<%= product_path(product) %>', '<%= j product.name %>')">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <!-- Mobile cards -->
      <div class="product-cards stagger">
        <% @products.each do |product| %>
          <div class="product-card <%= 'low-row' if product.current_stock <= product.reorder_level %>">
            <div class="flex items-center gap-12" style="margin-bottom:14px;">
              <% if product.photo.attached? %>
                <%= image_tag product.photo, class: "prod-thumb lg" %>
              <% else %>
                <div class="prod-thumb lg placeholder"><i class="fa-solid fa-box"></i></div>
              <% end %>
              <div style="flex:1; min-width:0;">
                <div style="font-weight:750; font-size:15.5px;"><%= product.name %></div>
                <div class="text-muted" style="font-size:12.5px;"><%= product.barcode %></div>
                <div style="font-size:12.5px; color:var(--accent); font-weight:700;"><%= product.category&.name || "Uncategorized" %></div>
              </div>
            </div>
            <div class="product-detail-grid">
              <div>
                <div class="text-muted" style="font-size:11px; font-weight:700; text-transform:uppercase;">Price</div>
                <div style="font-weight:750;">Rs. <%= product.selling_price_cents %></div>
              </div>
              <div>
                <div class="text-muted" style="font-size:11px; font-weight:700; text-transform:uppercase;">Stock</div>
                <div style="font-weight:750; <%= 'color:var(--danger);' if product.current_stock <= product.reorder_level %>">
                  <%= product.current_stock %> <%= product.unit %>
                </div>
              </div>
            </div>
            <div class="flex gap-10">
              <%= link_to edit_product_path(product), class: "btn btn-secondary btn-sm", style: "flex:1;" do %><i class="fa-solid fa-pen"></i> Edit<% end %>
              <button type="button" class="btn btn-danger btn-sm" onclick="deleteProduct('<%= product_path(product) %>', '<%= j product.name %>')">
                <i class="fa-solid fa-trash"></i>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<!-- Floating action button (mobile) -->
<a href="<%= new_product_path %>" class="fab-add" aria-label="Add Product"><i class="fa-solid fa-plus"></i></a>

<!-- Hidden delete form -->
<%= form_with url: "#", method: :delete, id: "productDeleteForm", local: true, html: { style: "display:none;" } do %><% end %>

<style>
  .filter-scroll{ display:flex; gap:10px; overflow-x:auto; padding-bottom:2px; }
  .filter-chip{
    padding:9px 16px; border-radius:20px; text-decoration:none; color:var(--text-muted); font-weight:650; font-size:13.5px;
    white-space:nowrap; border:1.6px solid var(--border); background:#fff; transition:.15s; flex-shrink:0;
  }
  .filter-chip.active{ background:var(--primary); color:#fff; border-color:var(--primary); }

  .prod-thumb{ width:42px; height:42px; border-radius:10px; object-fit:cover; flex-shrink:0; }
  .prod-thumb.placeholder{ background:var(--bg); display:flex; align-items:center; justify-content:center; color:var(--text-muted); }
  .prod-thumb.lg{ width:56px; height:56px; border-radius:14px; font-size:22px; }

  .products-table{ width:100%; border-collapse:collapse; display:none; }
  .products-table th{ text-align:left; padding:12px 10px; font-size:12px; text-transform:uppercase; letter-spacing:.03em; color:var(--text-muted); border-bottom:2px solid var(--border); }
  .products-table td{ padding:14px 10px; border-bottom:1px solid var(--border); vertical-align:middle; }
  .products-table tr.low-row{ background:var(--danger-light); }

  .product-cards{ display:grid; gap:14px; }
  .product-card{ background:var(--bg); border:1px solid var(--border); border-radius:16px; padding:16px; transition:.2s; }
  .product-card.low-row{ border-left:4px solid var(--danger); background:var(--danger-light); }
  .product-detail-grid{ display:grid; grid-template-columns:1fr 1fr; gap:10px; background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:12px 14px; margin-bottom:14px; }

  .fab-add{
    position:fixed; right:18px; bottom:calc(var(--tab-h) + var(--safe-bottom) + 16px); z-index:45;
    width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg,var(--primary),#7c6cf0); color:#fff;
    display:flex; align-items:center; justify-content:center; font-size:22px; text-decoration:none;
    box-shadow:0 10px 26px rgba(79,70,229,.4);
  }
  @media (min-width:900px){ .fab-add{ display:none; } .products-table{ display:table; } .product-cards{ display:none; } }
</style>

<script>
  function deleteProduct(url, name) {
    POS.confirm({
      title: 'Delete product?',
      body: `"${name}" will be permanently removed. This cannot be undone.`,
      confirmText: 'Delete',
      confirmClass: 'btn-danger',
      onConfirm: () => {
        const form = document.getElementById('productDeleteForm');
        form.action = url;
        form.submit();
      }
    });
  }
</script>
